  "author": "Habiba Khaled Mohammed <habibakhaled606@gmail.com>",
  "license": "ISC",
  "type": "module",
  "engines": {
    "node": ">=18.18.0"
  },
  "dependencies": {
    "@azure/identity": "^4.13.1",
    "@azure/identity-cache-persistence": "^1.2.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "dotenv": "^17.3.1",
    "tsx": "^4.19.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@types/node": "^22.19.17",
    "babel-loader": "^10.1.1",
    "typescript": "^5.7.2",
    "webpack": "^5.105.4",
    "webpack-cli": "^7.0.2"
  }
